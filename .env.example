# ================================================================
# ZAYA PLUS - Configuracao
# Copie este arquivo para .env e preencha os valores
# ================================================================

# --- OBRIGATORIO: Mente da Zaya (escolha um) ---
# OpenAI (ChatGPT) - https://platform.openai.com/api-keys
OPENAI_API_KEY=
# OU Groq (gratuito) - https://console.groq.com/keys
# OPENAI_API_KEY=gsk_...
# OPENAI_BASE_URL=https://api.groq.com/openai/v1

# Modelo de IA (padrao: gpt-4o)
AI_MODEL=gpt-4o
AI_MODEL_MINI=gpt-4o-mini

# --- OBRIGATORIO: Identidade ---
ADMIN_NAME=
ADMIN_NUMBER=
ADMIN_JID=
BOT_PASSWORD=admin
PORT=3001

# --- OPCIONAL: Voz da Zaya ---
# ElevenLabs - https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# Anthropic (Claude) - https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# --- OPCIONAL: WhatsApp ---
# WaSender - https://wasenderapi.com
WASENDER_API_KEY=
WASENDER_BASE_URL=https://www.wasenderapi.com/api

# --- OPCIONAL: Ligacoes ---
# Twilio - https://console.twilio.com
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_NGROK_DOMAIN=

# --- OPCIONAL: Meta (Instagram & Facebook) ---
# Token: https://developers.facebook.com/tools/explorer/
FACEBOOK_ACCESS_TOKEN=
META_PAGE_ID=
META_IG_ID=
META_AD_ACCOUNT_ID=
META_PAGE_TOKEN=

# WhatsApp Cloud API (Meta Business)
WHATSAPP_WABA_ID=
WHATSAPP_PHONE_ID=

# Instagram Scraper (cookie sessionid)
IG_SESSION_ID=

# --- OPCIONAL: Geracao de Imagens ---
# Google AI Studio - https://aistudio.google.com/apikey
GOOGLE_AI_STUDIO_KEY=

# --- OPCIONAL: Geracao de Videos ---
# Freepik (Kling) - https://www.freepik.com/api/keys
FREEPIK_API_KEY=

# --- OPCIONAL: Scraping (Apify) ---
# Apify - https://console.apify.com/settings/integrations
APIFY_API_TOKEN=

# --- OPCIONAL: Lip Sync ---
# Sync Labs - https://sync.so
SYNC_LABS_API_KEY=

# --- OPCIONAL: Pesquisa Web ---
# Firecrawl - https://firecrawl.dev
FIRECRAWL_API_KEY=

# Google Places - https://console.cloud.google.com
GOOGLE_PLACES_KEY=

# --- OPCIONAL: Armazenamento na Nuvem ---
# Supabase - https://supabase.com/dashboard
SUPABASE_URL=
SUPABASE_KEY=

# --- SISTEMA (auto-detectado, so altere se necessario) ---
# CHROME_PATH=/Applications/Google Chrome.app/Contents/MacOS/Google Chrome
# FFMPEG=/opt/homebrew/bin/ffmpeg
# FFPROBE=/opt/homebrew/bin/ffprobe
# WHISPER_BIN=whisper
# PYTHON3=python3
